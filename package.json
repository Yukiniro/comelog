{
  "name": "comelog",
  "version": "2.0.0",
  "description": "🎨 Comely style logs for the browser.",
  "main": "dist/comelog.cjs",
  "module": "dist/comelog.mjs",
  "types": "dist",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npx rollup -c rollup.config.mjs",
    "preview": "vite preview",
    "lint": "npx eslint src/**",
    "prettier": "npx prettier src/** --write",
    "test": "npx vitest",
    "test:run": "npx vitest run",
    "test:coverrage": "npx vitest --coverage",
    "publish:npm": "pnpm run build && pnpm publish"
  },
  "keywords": [
    "log",
    "console",
    "comely",
    "style",
    "chalk",
    "logger",
    "print"
  ],
  "author": "Yukiniro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Yukiniro/comelog"
  },
  "dependencies": {
    "camelcase-to-kebab": "^1.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@rollup/plugin-babel": "7.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@yukiniro/eslint-config": "^0.0.7",
    "c8": "^8.0.1",
    "eslint": "^8.57.1",
    "prettier": "^3.8.1",
    "prettier-eslint": "^16.4.2",
    "rollup": "^4.60.0",
    "rollup-plugin-filesize": "^10.0.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
